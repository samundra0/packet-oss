  realtimeInputPer1M               Int      @default(10) @map("realtime_input_per_1m") // $0.10 per 1M input tokens
  realtimeOutputPer1M              Int      @default(10) @map("realtime_output_per_1m") // $0.10 per 1M output tokens
  // Batch pricing (per 1M tokens, in cents) - discounted
  batch1hInputPer1M                Int      @default(7) @map("batch_1h_input_per_1m") // $0.07 per 1M - 30% discount
  batch1hOutputPer1M               Int      @default(7) @map("batch_1h_output_per_1m") // $0.07 per 1M
  batch24hInputPer1M               Int      @default(5) @map("batch_24h_input_per_1m") // $0.05 per 1M - 50% discount
  batch24hOutputPer1M              Int      @default(5) @map("batch_24h_output_per_1m") // $0.05 per 1M
