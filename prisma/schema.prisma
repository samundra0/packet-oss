  value     String   @db.Text
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_setting")
}

model CustomerCache {
  id              String   @id // Stripe customer ID (cus_xxx)
  email           String?
  name            String?
  stripeCreatedAt DateTime @map("stripe_created_at")
  balanceCents    Int      @default(0) @map("balance_cents") // raw Stripe balance (negative = credit)
  billingType     String?  @map("billing_type")
  teamId          String?  @map("team_id") // metadata.hostedai_team_id
  productId       String?  @map("product_id") // metadata.packet_product_id
  metadataJson    String?  @map("metadata_json") @db.Text // full metadata JSON fallback
  activePods      Int      @default(0) @map("active_pods") // live pod count from hosted.ai
  isDeleted       Boolean  @default(false) @map("is_deleted")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([billingType])
  @@index([teamId])
  @@index([stripeCreatedAt])
  @@map("customer_cache")
}

model AdminLoginLog {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ip        String?
  method    String   // "password" | "magic-link" | "invite-setup" | "2fa"
  reason    String?  // null=success, "invalid-password" | "invalid-2fa" | "rate-limited"
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([createdAt])
  @@index([success])
  @@map("admin_login_log")
}
