generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ActivityEvent {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  type        String
  description String
  metadata    String?  @db.Text
  tenantId    String   @default("default") @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("activity_event")
}

model TeamMember {
  id               String    @id @default(cuid())
  email            String
  name             String?
  stripeCustomerId String    @map("stripe_customer_id")
  role             String    @default("member")
  invitedAt        DateTime  @default(now()) @map("invited_at")
  acceptedAt       DateTime? @map("accepted_at")
  invitedBy        String?   @map("invited_by")
  tenantId         String    @default("default") @map("tenant_id")

  @@unique([email, stripeCustomerId])
  @@index([email])
  @@index([stripeCustomerId])
  @@index([tenantId])
  @@map("team_member")
}

model Investor {
  id                  String    @id @default(cuid())
  email               String    @unique
  addedBy             String    @map("added_by")
  isOwner             Boolean   @default(false) @map("is_owner")
  acceptedAt          DateTime? @map("accepted_at")
  lastLoginAt         DateTime? @map("last_login_at")
  assignedNodeIds     String    @default("[]") @map("assigned_node_ids") @db.Text
  revenueSharePercent Float?    @map("revenue_share_percent")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@map("investor")
}

model SSHKey {
  id               String   @id @default(cuid())
  stripeCustomerId String   @map("stripe_customer_id")
  name             String
  publicKey        String   @map("public_key") @db.Text
  fingerprint      String
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([stripeCustomerId, fingerprint])
  @@index([stripeCustomerId])
  @@map("ssh_key")
}

model PodMetadata {
  id                   String    @id @default(cuid())
  subscriptionId       String    @unique @map("subscription_id")
  instanceId           String?   @unique @map("instance_id") // HostedAI 2.2 unified instance UUID
  stripeCustomerId     String    @map("stripe_customer_id")
  displayName          String?   @map("display_name")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deployTime           DateTime? @map("deploy_time")
  hourlyRateCents      Int?      @map("hourly_rate_cents")
  poolId               String?   @map("pool_id")
  prepaidAmountCents   Int?      @map("prepaid_amount_cents")
  prepaidUntil         DateTime? @map("prepaid_until")
  productId            String?   @map("product_id")
  metricsToken         String?   @map("metrics_token")
  startupScript        String?   @map("startup_script") @db.Text // Custom startup script to run after pod starts
  startupScriptStatus  String?   @map("startup_script_status") // "pending", "running", "completed", "failed"
  startupScriptOutput  String?   @map("startup_script_output") @db.Text // Output/error from script execution
  storageAlertSent     Boolean   @default(false) @map("storage_alert_sent") // Whether 80% storage warning was sent
  skypilotTags         String?   @map("skypilot_tags") @db.Text // JSON tags for SkyPilot cluster tracking (e.g. {"skypilot-cluster-name": "my-cluster"})
  billingType          String?   @map("billing_type") // "hourly" or "monthly" - null for legacy pods
  stripeSubscriptionId String?   @map("stripe_subscription_id") // Links monthly pod to the Stripe subscription that pays for it
  sharedVolumeId       Int?      @map("shared_volume_id")    // hosted.ai shared volume ID for persistent workspace
  tenantId             String    @default("default") @map("tenant_id")
  tenantLastBilledAt   DateTime? @map("tenant_last_billed_at") // Last time this pod was billed via tenant wallet

  @@index([stripeCustomerId])
  @@index([prepaidUntil])
  @@index([metricsToken])
  @@index([stripeSubscriptionId])
  @@index([tenantId])
  @@map("pod_metadata")
}

model PodFailureAlert {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  podName        String   @map("pod_name")
  teamId         String   @map("team_id")
  customerEmail  String?  @map("customer_email")
  poolName       String?  @map("pool_name")
  podStatus      String   @map("pod_status") // The failed status that triggered the alert
  zammadTicketId Int?     @map("zammad_ticket_id") // Zammad ticket ID if created
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([subscriptionId, podName]) // One alert per pod per subscription
  @@index([teamId])
  @@index([createdAt])
  @@map("pod_failure_alert")
}

model HuggingFaceDeployment {
  id               String   @id @default(cuid())
  subscriptionId   String   @map("subscription_id")
  stripeCustomerId String   @map("stripe_customer_id")
  hfItemId         String   @map("hf_item_id")
  hfItemType       String   @map("hf_item_type")
  hfItemName       String   @map("hf_item_name")
  deployScript     String   @map("deploy_script") @db.Text
  status           String   @default("pending")
  deployOutput     String?  @map("deploy_output") @db.Text
  servicePort      Int?     @map("service_port")
  webUiPort        Int?     @map("web_ui_port")
  openWebUI        Boolean  @default(false) @map("open_web_ui")
  netdataPort      Int?     @map("netdata_port")
  netdata          Boolean  @default(false)
  hfToken          String?  @map("hf_token")
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([stripeCustomerId])
  @@index([subscriptionId])
  @@index([status])
  @@map("hugging_face_deployment")
}

model TwoFactorAuth {
  id          String    @id @default(cuid())
  email       String    @unique
  secret      String
  verified    Boolean   @default(false)
  backupCodes String?   @map("backup_codes") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastUsedAt  DateTime? @map("last_used_at")

  @@index([email])
  @@map("two_factor_auth")
}

model AdminPin {
  id             String   @id @default(cuid())
  email          String   @unique
  pinHash        String   @map("pin_hash")
  salt           String
  expiresAt      DateTime @map("expires_at")
  previousHashes String?  @map("previous_hashes") @db.Text // JSON array of {salt, hash} for reuse prevention
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("admin_pin")
}

model AdminActivityEvent {
  id          String   @id @default(cuid())
  adminEmail  String   @map("admin_email")
  type        String
  description String
  metadata    String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminEmail])
  @@index([createdAt])
  @@index([type])
  @@map("admin_activity_event")
}

model VllmMetrics {
  id                    String   @id @default(cuid())
  subscriptionId        String   @map("subscription_id")
  stripeCustomerId      String   @map("stripe_customer_id")
  promptTokens          BigInt   @map("prompt_tokens")
  generationTokens      BigInt   @map("generation_tokens")
  totalTokens           BigInt   @map("total_tokens")
  promptTokensDelta     BigInt   @default(0) @map("prompt_tokens_delta")
  generationTokensDelta BigInt   @default(0) @map("generation_tokens_delta")
  totalTokensDelta      BigInt   @default(0) @map("total_tokens_delta")
  walletBalanceCents    Int?     @map("wallet_balance_cents")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([subscriptionId, createdAt])
  @@index([stripeCustomerId, createdAt])
  @@map("vllm_metrics")
}

model ReferralCode {
  id               String          @id @default(cuid())
  code             String          @unique
  stripeCustomerId String          @unique @map("stripe_customer_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  claims           ReferralClaim[]

  @@index([stripeCustomerId])
  @@index([code])
  @@map("referral_code")
}

model ReferralClaim {
  id                String       @id @default(cuid())
  referralCodeId    String       @map("referral_code_id")
  refereeCustomerId String       @unique @map("referee_customer_id")
  refereeEmail      String       @map("referee_email")
  status            String       @default("pending")
  qualifiedAt       DateTime?    @map("qualified_at")
  creditedAt        DateTime?    @map("credited_at")
  referrerCredited  Boolean      @default(false) @map("referrer_credited")
  refereeCredited   Boolean      @default(false) @map("referee_credited")
  createdAt         DateTime     @default(now()) @map("created_at")
  referralCode      ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  @@index([referralCodeId])
  @@index([status])
  @@map("referral_claim")
}

model Voucher {
  id              String              @id @default(cuid())
  code            String              @unique
  name            String
  description     String?
  creditCents     Int                 @map("credit_cents")
  minTopupCents   Int?                @map("min_topup_cents")
  maxRedemptions  Int?                @map("max_redemptions")
  redemptionCount Int                 @default(0) @map("redemption_count")
  maxPerCustomer  Int                 @default(1) @map("max_per_customer")
  startsAt        DateTime?           @map("starts_at")
  expiresAt       DateTime?           @map("expires_at")
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  createdBy       String?             @map("created_by")
  redemptions     VoucherRedemption[]

  @@index([code])
  @@index([active])
  @@map("voucher")
}

model VoucherRedemption {
  id               String   @id @default(cuid())
  voucherId        String   @map("voucher_id")
  stripeCustomerId String   @map("stripe_customer_id")
  customerEmail    String   @map("customer_email")
  topupCents       Int      @map("topup_cents")
  creditCents      Int      @map("credit_cents")
  stripeSessionId  String?  @map("stripe_session_id")
  createdAt        DateTime @default(now()) @map("created_at")
  tenantId         String   @default("default") @map("tenant_id")
  voucher          Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([stripeCustomerId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("voucher_redemption")
}

model PodSnapshot {
  id                     String    @id @default(cuid())
  stripeCustomerId       String    @map("stripe_customer_id")
  displayName            String    @map("display_name")
  notes                  String?
  snapshotType           String    @default("template") @map("snapshot_type")
  originalSubscriptionId String?   @map("original_subscription_id")
  poolId                 String    @map("pool_id")
  poolName               String?   @map("pool_name")
  regionId               String?   @map("region_id")
  vgpus                  Int
  instanceTypeId         String?   @map("instance_type_id")
  imageUuid              String?   @map("image_uuid")
  persistentVolumeId     Int?      @map("persistent_volume_id")
  persistentVolumeName   String?   @map("persistent_volume_name")
  persistentVolumeSize   Int?      @map("persistent_volume_size")
  autoCreatedVolume      Boolean   @default(false) @map("auto_created_volume")
  storageBlockId         String?   @map("storage_block_id")
  hfItemId               String?   @map("hf_item_id")
  hfItemType             String?   @map("hf_item_type")
  hfItemName             String?   @map("hf_item_name")
  deployScript           String?   @map("deploy_script") @db.Text
  autoPreserved          Boolean   @default(false) @map("auto_preserved") // Auto-created on non-payment termination
  expiresAt              DateTime? @map("expires_at") // When auto-preserved snapshot should be cleaned up (7 days)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([stripeCustomerId])
  @@index([snapshotType])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("pod_snapshot")
}

model SupportNotification {
  id               String   @id @default(cuid())
  ticketId         String   @map("ticket_id") // Zammad ticket ID (as string for compatibility)
  stripeCustomerId String   @map("stripe_customer_id")
  customerEmail    String   @map("customer_email")
  lastArticleId    Int      @map("last_article_id") // Zammad article ID
  lastArticleAt    DateTime @map("last_article_at")
  sentAt           DateTime @default(now()) @map("sent_at")

  @@unique([ticketId, lastArticleId])
  @@index([ticketId])
  @@index([stripeCustomerId])
  @@map("support_notification")
}

model ContactSubmission {
  id               String   @id @default(cuid())
  name             String
  email            String
  subject          String
  message          String   @db.Text
  priority         String   @default("normal")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("contact_submissions")
}

model ApiKey {
  id               String    @id @default(cuid())
  name             String
  keyPrefix        String    @map("key_prefix")
  keyHash          String    @unique @map("key_hash")
  stripeCustomerId String    @map("stripe_customer_id")
  teamId           String    @map("team_id")
  scopes           String    @default("*")
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime? @map("expires_at")
  rateLimitRpm     Int?      @map("rate_limit_rpm") // Per-key RPM override (null = use customer default)
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  @@index([stripeCustomerId])
  @@index([keyHash])
  @@map("api_key")
}

model ServiceProvider {
  id                      String                    @id @default(cuid())
  email                   String                    @unique
  companyName             String                    @map("company_name")
  contactName             String                    @map("contact_name")
  phone                   String?
  website                 String?
  verified                Boolean                   @default(false)
  verifiedAt              DateTime?                 @map("verified_at")
  verifiedBy              String?                   @map("verified_by")
  estimatedGpuCount       Int?                      @map("estimated_gpu_count")
  gpuTypes                String?                   @map("gpu_types")
  regions                 String?
  applicationType         String                    @default("gpu_provider") @map("application_type") // "gpu_provider" or "white_label"
  desiredDomain           String?                   @map("desired_domain")
  expectedCustomers       String?                   @map("expected_customers")
  status                  String                    @default("pending")
  suspendedReason         String?                   @map("suspended_reason")
  terminatedAt            DateTime?                 @map("terminated_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  commercialEmail         String?                   @map("commercial_email")
  commercialPhone         String?                   @map("commercial_phone")
  generalEmail            String?                   @map("general_email")
  supportEmail            String?                   @map("support_email")
  supportPhone            String?                   @map("support_phone")
  commercialTerms         ProviderCommercialTerms[]
  nodes                   ProviderNode[]
  notifications           ProviderNotification[]
  payouts                 ProviderPayout[]
  inferenceProviderConfig InferenceProviderConfig? // NEW: Token revenue config

  @@index([status])
  @@index([email])
  @@map("service_provider")
}

model ProviderNode {
  id                      String                @id @default(cuid())
  providerId              String                @map("provider_id")
  hostname                String
  ipAddress               String                @map("ip_address")
  sshPort                 Int                   @default(22) @map("ssh_port")
  sshUsername             String                @default("root") @map("ssh_username")
  requestedGpuTypeId      String?               @map("requested_gpu_type_id")
  gpuModel                String?               @map("gpu_model")
  gpuCount                Int?                  @map("gpu_count")
  cpuModel                String?               @map("cpu_model")
  cpuCores                Int?                  @map("cpu_cores")
  ramGb                   Int?                  @map("ram_gb")
  storageGb               Int?                  @map("storage_gb")
  networkSpeedMbps        Int?                  @map("network_speed_mbps")
  datacenter              String?
  region                  String?
  country                 String?
  pricingTierId           String?               @map("pricing_tier_id")
  customProviderRateCents Int?                  @map("custom_provider_rate_cents")
  revenueSharePercent     Float?                @map("revenue_share_percent")
  selectedPayoutModel     String?               @map("selected_payout_model")
  status                  String                @default("pending_validation")
  statusMessage           String?               @map("status_message")
  validatedAt             DateTime?             @map("validated_at")
  validationError         String?               @map("validation_error")
  osVersion               String?               @map("os_version")
  approvedAt              DateTime?             @map("approved_at")
  approvedBy              String?               @map("approved_by")
  rejectedAt              DateTime?             @map("rejected_at")
  rejectedBy              String?               @map("rejected_by")
  rejectionReason         String?               @map("rejection_reason")
  hostedaiPoolId          String?               @map("hostedai_pool_id")
  hostedaiNodeId          String?               @map("hostedai_node_id")
  gpuaasNodeId            Int?                  @map("gpuaas_node_id")
  gpuaasRegionId          Int?                  @map("gpuaas_region_id")
  gpuaasClusterId         Int?                  @map("gpuaas_cluster_id")
  gpuaasPoolId            Int?                  @map("gpuaas_pool_id")
  gpuaasInitStatus        String?               @map("gpuaas_init_status")
  gpuaasSshKeysInstalled  Boolean               @default(false) @map("gpuaas_ssh_keys_installed")
  externalServiceIp       String?               @map("external_service_ip")
  removalRequestedAt      DateTime?             @map("removal_requested_at")
  removalScheduledFor     DateTime?             @map("removal_scheduled_for")
  removalReason           String?               @map("removal_reason")
  removedAt               DateTime?             @map("removed_at")
  lastHealthCheck         DateTime?             @map("last_health_check")
  healthStatus            String?               @map("health_status")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  deletionConfirmedAt     DateTime?             @map("deletion_confirmed_at")
  gpuaasSshKeys           String?               @map("gpuaas_ssh_keys") @db.Text
  sshPassword             String?               @map("ssh_password")
  poolSettings            PoolSettingsOverride?
  pricingTier             ProviderPricingTier?  @relation(fields: [pricingTierId], references: [id])
  requestedGpuType        AllowedGpuType?       @relation(fields: [requestedGpuTypeId], references: [id])
  provider                ServiceProvider       @relation(fields: [providerId], references: [id])
  usageRecords            ProviderNodeUsage[]
  inferenceServers        InferenceServer[] // NEW: Inference servers on this node

  @@index([providerId])
  @@index([status])
  @@index([pricingTierId])
  @@map("provider_node")
}

model ProviderPricingTier {
  id                   String         @id @default(cuid())
  name                 String
  description          String?
  gpuModel             String         @map("gpu_model")
  providerRateCents    Int            @map("provider_rate_cents")
  customerRateCents    Int            @map("customer_rate_cents")
  isRevenueShare       Boolean        @default(false) @map("is_revenue_share")
  revenueSharePercent  Float?         @map("revenue_share_percent")
  minProviderRateCents Int?           @map("min_provider_rate_cents")
  active               Boolean        @default(true)
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  nodes                ProviderNode[]

  @@index([gpuModel])
  @@index([active])
  @@map("provider_pricing_tier")
}

model ProviderNodeUsage {
  id                    String       @id @default(cuid())
  nodeId                String       @map("node_id")
  periodStart           DateTime     @map("period_start")
  periodEnd             DateTime     @map("period_end")
  totalHours            Float        @map("total_hours")
  occupiedHours         Float        @map("occupied_hours")
  utilizationPercent    Float?       @map("utilization_percent")
  customerRevenueCents  Int          @map("customer_revenue_cents")
  providerEarningsCents Int          @map("provider_earnings_cents")
  packetMarginCents     Int          @map("packet_margin_cents")
  createdAt             DateTime     @default(now()) @map("created_at")
  node                  ProviderNode @relation(fields: [nodeId], references: [id])

  @@index([nodeId, periodStart])
  @@index([periodStart])
  @@map("provider_node_usage")
}

model ProviderPayout {
  id                 String          @id @default(cuid())
  providerId         String          @map("provider_id")
  periodStart        DateTime        @map("period_start")
  periodEnd          DateTime        @map("period_end")
  grossEarningsCents Int             @map("gross_earnings_cents")
  deductionsCents    Int             @default(0) @map("deductions_cents")
  netPayoutCents     Int             @map("net_payout_cents")
  breakdown          String?
  status             String          @default("pending")
  processedAt        DateTime?       @map("processed_at")
  paidAt             DateTime?       @map("paid_at")
  transactionRef     String?         @map("transaction_ref")
  failureReason      String?         @map("failure_reason")
  invoiceNumber      String?         @map("invoice_number")
  invoiceUrl         String?         @map("invoice_url")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  provider           ServiceProvider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@index([periodStart])
  @@map("provider_payout")
}

model ProviderNotification {
  id         String          @id @default(cuid())
  providerId String          @map("provider_id")
  type       String
  subject    String
  nodeId     String?         @map("node_id")
  payoutId   String?         @map("payout_id")
  metadata   String?         @db.Text
  sentAt     DateTime        @default(now()) @map("sent_at")
  provider   ServiceProvider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([type])
  @@index([sentAt])
  @@map("provider_notification")
}

model ProviderAdminActivity {
  id         String   @id @default(cuid())
  adminEmail String   @map("admin_email")
  action     String
  providerId String?  @map("provider_id")
  nodeId     String?  @map("node_id")
  payoutId   String?  @map("payout_id")
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([adminEmail])
  @@index([providerId])
  @@index([action])
  @@index([createdAt])
  @@map("provider_admin_activity")
}

model AllowedGpuType {
  id                         String         @id @default(cuid())
  name                       String         @unique
  shortName                  String         @map("short_name")
  manufacturer               String         @default("NVIDIA")
  matchPatterns              String         @map("match_patterns") @db.Text
  defaultProviderRateCents   Int            @map("default_provider_rate_cents")
  defaultCustomerRateCents   Int            @map("default_customer_rate_cents")
  defaultTermsType           String         @default("fixed") @map("default_terms_type")
  defaultRevenueSharePercent Float?         @map("default_revenue_share_percent")
  payoutModelChoice          String         @default("fixed_only") @map("payout_model_choice")
  minVramGb                  Int?           @map("min_vram_gb")
  minCudaCores               Int?           @map("min_cuda_cores")
  acceptingSubmissions       Boolean        @default(true) @map("accepting_submissions")
  displayOrder               Int            @default(0) @map("display_order")
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")
  nodes                      ProviderNode[]

  @@index([acceptingSubmissions])
  @@map("allowed_gpu_type")
}

model ProcessedStripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  processedAt   DateTime @default(now()) @map("processed_at")
  sessionId     String?  @map("session_id")
  customerId    String?  @map("customer_id")

  @@index([stripeEventId])
  @@index([sessionId])
  @@index([customerId])
  @@index([processedAt])
  @@map("processed_stripe_event")
}

model PodMetricsHistory {
  id             String   @id @default(cuid())
  teamId         String   @map("team_id")
  subscriptionId String   @map("subscription_id")
  tflopsUsage    Float    @default(0) @map("tflops_usage")
  vramUsageKb    Float    @default(0) @map("vram_usage_kb")
