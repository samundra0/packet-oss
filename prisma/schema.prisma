// ============================================================
// WHITE-LABEL MULTI-TENANCY
// ============================================================

model Tenant {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  status                String   @default("active")

  // Contact (reseller admin)
  contactEmail          String?  @map("contact_email")
  contactName           String?  @map("contact_name")

  // Branding
  brandName             String   @map("brand_name")
  logoUrl               String   @default("") @map("logo_url")
  faviconUrl            String?  @map("favicon_url")
  ogImageUrl            String?  @map("og_image_url")
  primaryColor          String   @default("#1a4fff") @map("primary_color")
  accentColor           String   @default("#18b6a8") @map("accent_color")
  bgColor               String   @default("#f7f8fb") @map("bg_color")
  textColor             String   @default("#0b0f1c") @map("text_color")
  customCss             String?  @map("custom_css") @db.Text
  customStrings         Json?    @map("custom_strings")

  // Their Stripe (encrypted at rest via src/lib/crypto.ts)
  stripeSecretKey       String   @default("") @map("stripe_secret_key")
  stripePublishableKey  String   @default("") @map("stripe_publishable_key")
  stripeWebhookSecret   String   @default("") @map("stripe_webhook_secret")

  // Our billing to them
  wholesaleCustomerId   String?  @map("wholesale_customer_id")

  // Pricing
  signupCreditCents     Int      @default(0) @map("signup_credit_cents")
  billingModels         String   @default("hourly,monthly") @map("billing_models")

  // Support & operations
  supportEmail          String   @default("") @map("support_email")
  supportUrl            String?  @map("support_url")
  statusPageEnabled     Boolean  @default(true) @map("status_page_enabled")
  alertWebhookUrl       String?  @map("alert_webhook_url")

  // GTM & integrations
  leadWebhookUrl        String?  @map("lead_webhook_url")
  analyticsId           String?  @map("analytics_id")
  dripEmailEnabled      Boolean  @default(true) @map("drip_email_enabled")

  // Access control
  adminDomains          String   @default("hosted.ai") @map("admin_domains")
  allowedGpuTypes       String   @default("rtx-pro-6000,b200,h200") @map("allowed_gpu_types")
  maxConcurrentGpus     Int?     @map("max_concurrent_gpus")

  // API access (for WHMCS / custom integrations)
  apiKey                String?  @unique @map("api_key")
  webhookUrl            String?  @map("webhook_url")

  // CLI
  cliName               String?  @map("cli_name")
  cliDownloadUrl        String?  @map("cli_download_url")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  domains               TenantDomain[]
  gpuPricing            TenantGpuPricing[]
  customers             TenantCustomer[]
  dripTemplates         TenantDripTemplate[]

  @@map("tenant")
}

