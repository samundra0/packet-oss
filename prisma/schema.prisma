  sessionId           String   @map("session_id") // random ID per browser session (sessionStorage)
  page                String // pathname, e.g. "/", "/account", "/features"
  referrer            String?  @db.Text
  utmSource           String?  @map("utm_source")
  utmMedium           String?  @map("utm_medium")
  utmCampaign         String?  @map("utm_campaign")
  utmContent          String?  @map("utm_content")
  utmTerm             String?  @map("utm_term")
  convertedCustomerId String?  @map("converted_customer_id") // filled on signup, links to Stripe customer
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([utmSource])
  @@index([utmCampaign])
  @@index([createdAt])
  @@index([sessionId])
  @@index([convertedCustomerId])
  @@map("page_view")
}

// ─── Marketing: full customer lifecycle with attribution ───
// One row per customer. Tracks attribution source + every milestone + running LTV.
// Updated by signup API, webhook handlers, and cron jobs as events happen.
model CustomerLifecycle {
  id               String @id @default(cuid())
  stripeCustomerId String @unique @map("stripe_customer_id")
  email            String
  tenantId         String @default("default") @map("tenant_id")

  // ── Attribution (set once at signup, never overwritten) ──
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmContent  String? @map("utm_content")
  utmTerm     String? @map("utm_term")
  landingPage String? @map("landing_page") @db.Text
  referrer    String? @db.Text
  sessionId   String? @map("session_id") // links to PageView records

  // ── Lifecycle milestones (timestamps, null = not reached yet) ──
  signedUpAt       DateTime  @map("signed_up_at") // when account was created
  firstLoginAt     DateTime? @map("first_login_at") // first dashboard access
  firstApiCallAt   DateTime? @map("first_api_call_at") // first Token Factory call
  firstDepositAt   DateTime? @map("first_deposit_at") // first wallet topup
  firstGpuDeployAt DateTime? @map("first_gpu_deploy_at") // first pod launched
  subscribedAt     DateTime? @map("subscribed_at") // converted to monthly subscription
  churnedAt        DateTime? @map("churned_at") // stopped paying / all pods terminated
  reactivatedAt    DateTime? @map("reactivated_at") // came back after churn

  // ── Financials (running totals, updated on each event) ──
  totalDepositsCents Int    @default(0) @map("total_deposits_cents") // lifetime wallet deposits
  totalSpendCents    Int    @default(0) @map("total_spend_cents") // lifetime spend (GPU + inference)
  depositCount       Int    @default(0) @map("deposit_count") // number of topups
  currentBillingType String @default("free") @map("current_billing_type") // free, hourly, monthly

  // ── Engagement ──
  lastActiveAt    DateTime? @map("last_active_at") // last meaningful action
  gpuHoursTotal   Float     @default(0) @map("gpu_hours_total") // lifetime GPU hours
  inferenceTokens Int       @default(0) @map("inference_tokens") // lifetime tokens used

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([utmSource])
  @@index([utmCampaign])
  @@index([utmMedium])
  @@index([signedUpAt])
  @@index([currentBillingType])
  @@index([totalDepositsCents])
  @@index([churnedAt])
  @@index([tenantId])
  @@map("customer_lifecycle")
}

