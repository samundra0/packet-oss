// ============================================
// Token Factory - Batch & Real-time Inference
// ============================================

model InferenceModel {
  id               String              @id @default(cuid())
  name             String              @unique // e.g. "meta-llama/Llama-3.1-8B-Instruct"
  displayName      String              @map("display_name") // e.g. "Llama 3.1 8B Instruct"
  provider         String              @default("packet") // packet, openai, anthropic
  modelType        String              @default("chat") @map("model_type") // chat, completion, embedding
  contextLength    Int                 @default(8192) @map("context_length")
  inputPricePer1k  Float               @default(0) @map("input_price_per_1k") // Price per 1k input tokens (cents)
  outputPricePer1k Float               @default(0) @map("output_price_per_1k") // Price per 1k output tokens (cents)
  batchDiscount    Float               @default(0.5) @map("batch_discount") // 50% off for batch
  vramRequiredGb   Int?                @map("vram_required_gb") // Minimum VRAM needed
  gpuTypes         String?             @map("gpu_types") // JSON array of compatible GPU types
  supportsLora     Boolean             @default(true) @map("supports_lora")
  active           Boolean             @default(true)
  featured         Boolean             @default(false)
  displayOrder     Int                 @default(0) @map("display_order")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  loraAdapters     LoraAdapter[]
  batchJobs        InferenceBatchJob[]

  @@index([active])
  @@index([provider])
  @@map("inference_model")
}

model LoraAdapter {
  id               String              @id @default(cuid())
  stripeCustomerId String              @map("stripe_customer_id")
  teamId           String              @map("team_id")
  baseModelId      String              @map("base_model_id")
  name             String // User-defined name e.g. "support-bot-v2"
  displayName      String?             @map("display_name") // Optional display name
  description      String?
  trainingFile     String?             @map("training_file") // S3 path to training JSONL
  trainingStatus   String              @default("pending") @map("training_status") // pending, training, ready, failed
  trainingProgress Int                 @default(0) @map("training_progress") // 0-100
  trainingError    String?             @map("training_error") @db.Text
  adapterPath      String?             @map("adapter_path") // Path to LoRA weights on inference server
  adapterSizeMb    Float?              @map("adapter_size_mb")
  epochs           Int                 @default(3)
  learningRate     Float               @default(0.0002) @map("learning_rate")
  rank             Int                 @default(16) // LoRA rank
  alpha            Int                 @default(32) // LoRA alpha
  totalTokens      BigInt              @default(0) @map("total_tokens") // Tokens used for inference
  lastUsedAt       DateTime?           @map("last_used_at")
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  baseModel        InferenceModel      @relation(fields: [baseModelId], references: [id])
  batchJobs        InferenceBatchJob[]

  @@unique([teamId, name])
  @@index([stripeCustomerId])
  @@index([teamId])
  @@index([baseModelId])
  @@index([trainingStatus])
  @@map("lora_adapter")
}

model InferenceBatchJob {
  id                 String             @id @default(cuid())
  stripeCustomerId   String             @map("stripe_customer_id")
  teamId             String             @map("team_id")
  modelId            String             @map("model_id")
  loraAdapterId      String?            @map("lora_adapter_id")
  inputFile          String             @map("input_file") @db.LongText // JSONL content (can be very large)
  outputFile         String?            @map("output_file") @db.LongText // JSONL output content
  status             String             @default("pending") // pending, validating, queued, processing, completed, failed, cancelled
  slaType            String             @default("24h") @map("sla_type") // 1h, 24h
  priority           Int                @default(0) // Higher = processed first
  totalRequests      Int                @default(0) @map("total_requests")
  completedRequests  Int                @default(0) @map("completed_requests")
  failedRequests     Int                @default(0) @map("failed_requests")
  inputTokens        BigInt             @default(0) @map("input_tokens")
  outputTokens       BigInt             @default(0) @map("output_tokens")
  estimatedCostCents Int                @default(0) @map("estimated_cost_cents")
  actualCostCents    Int                @default(0) @map("actual_cost_cents")
  errorMessage       String?            @map("error_message") @db.Text
  startedAt          DateTime?          @map("started_at")
  completedAt        DateTime?          @map("completed_at")
  deadline           DateTime? // SLA deadline
  metadata           String? @db.Text // JSON metadata
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  model              InferenceModel     @relation(fields: [modelId], references: [id])
  loraAdapter        LoraAdapter?       @relation(fields: [loraAdapterId], references: [id])
  requests           InferenceRequest[]

  @@index([stripeCustomerId])
  @@index([teamId])
  @@index([status])
  @@index([deadline])
  @@index([createdAt])
  @@map("inference_batch_job")
}

model InferenceRequest {
  id           String             @id @default(cuid())
  batchJobId   String?            @map("batch_job_id")
  customId     String?            @map("custom_id") // User-provided custom ID for matching
  inputData    String             @map("input_data") @db.Text // JSON request body
  outputData   String?            @map("output_data") @db.Text // JSON response
  status       String             @default("pending") // pending, processing, completed, failed
  inputTokens  Int                @default(0) @map("input_tokens")
  outputTokens Int                @default(0) @map("output_tokens")
  latencyMs    Int?               @map("latency_ms")
  errorMessage String?            @map("error_message")
  processedAt  DateTime?          @map("processed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  batchJob     InferenceBatchJob? @relation(fields: [batchJobId], references: [id])

  @@index([batchJobId])
  @@index([status])
  @@index([customId])
  @@map("inference_request")
}

model InferenceUsage {
  id               String           @id @default(cuid())
  stripeCustomerId String           @map("stripe_customer_id")
  teamId           String           @map("team_id")
  modelId          String?          @map("model_id")
  loraAdapterId    String?          @map("lora_adapter_id")
  requestType      String           @default("realtime") @map("request_type") // realtime, batch
  inputTokens      BigInt           @map("input_tokens")
  outputTokens     BigInt           @map("output_tokens")
  costCents        Int              @map("cost_cents")
  latencyMs        Int?             @map("latency_ms")
  serverId         String?          @map("server_id") // NEW: Track which server processed this
  createdAt        DateTime         @default(now()) @map("created_at")
  server           InferenceServer? @relation(fields: [serverId], references: [id])

  @@index([stripeCustomerId, createdAt])
  @@index([teamId, createdAt])
  @@index([modelId])
  @@index([serverId])
  @@map("inference_usage")
}

model InferenceServer {
  id             String                 @id @default(cuid())
  hostname       String
  ipAddress      String                 @map("ip_address")
  port           Int                    @default(8000)
  gpuType        String                 @map("gpu_type") // e.g. "RTX 4090"
  gpuCount       Int                    @default(1) @map("gpu_count")
  vramTotalGb    Int                    @map("vram_total_gb")
  loadedModel    String?                @map("loaded_model") // Currently loaded model
  loadedLoras    String?                @map("loaded_loras") @db.Text // JSON array of loaded LoRA adapter IDs
  status         String                 @default("offline") // offline, starting, ready, busy, error
  healthCheckAt  DateTime?              @map("health_check_at")
  currentLoad    Float                  @default(0) @map("current_load") // 0-100 utilization
  queueDepth     Int                    @default(0) @map("queue_depth")
  providerNodeId String?                @map("provider_node_id") // NEW: Link to provider infrastructure
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  providerNode   ProviderNode?          @relation(fields: [providerNodeId], references: [id])
  usageRecords   InferenceUsage[]
  serverUsage    InferenceServerUsage[]

  @@unique([ipAddress, port])
  @@index([status])
  @@index([loadedModel])
  @@index([providerNodeId])
  @@map("inference_server")
}

// Token usage tracking per inference server (for provider revenue)
model InferenceServerUsage {
  id                    String          @id @default(cuid())
  serverId              String          @map("server_id")
  providerId            String          @map("provider_id")
  periodStart           DateTime        @map("period_start")
  periodEnd             DateTime        @map("period_end")
  inputTokens           BigInt          @map("input_tokens")
  outputTokens          BigInt          @map("output_tokens")
  totalTokens           BigInt          @map("total_tokens")
  requestCount          Int             @map("request_count")
  customerRevenueCents  Int             @default(0) @map("customer_revenue_cents") // What customers paid (whole cents)
  providerEarningsCents Int             @default(0) @map("provider_earnings_cents") // Provider's share (whole cents)
  packetMarginCents     Int             @default(0) @map("packet_margin_cents") // Packet's margin (whole cents)
  createdAt             DateTime        @default(now()) @map("created_at")
